CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Adjust" "${PODS_CONFIGURATION_BUILD_DIR}/Realm" "${PODS_ROOT}/AdjustSignature" "${PODS_ROOT}/Realm/core" "${PODS_XCFRAMEWORKS_BUILD_DIR}/AdjustSignature"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/Adjust/AdjustSdk.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/Realm/Realm.framework/Headers" "${PODS_XCFRAMEWORKS_BUILD_DIR}/Realm/Headers"
LD_RUNPATH_SEARCH_PATHS = $(inherited) '@executable_path/Frameworks' '@loader_path/Frameworks'
LIBRARY_SEARCH_PATHS = $(inherited) "${PODS_XCFRAMEWORKS_BUILD_DIR}/Realm"
OTHER_LDFLAGS = $(inherited) -l"c++" -l"compression" -l"z" -framework "AdjustSdk" -framework "AdjustSigSdk" -framework "Foundation" -framework "QuartzCore" -framework "Realm" -framework "Security" -framework "SystemConfiguration" -weak_framework "AdSupport" -weak_framework "UIKit"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/Adjust" "-F${PODS_CONFIGURATION_BUILD_DIR}/AdjustSignature" "-F${PODS_CONFIGURATION_BUILD_DIR}/Realm"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
